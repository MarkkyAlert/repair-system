# =============================================================================
# Repair System — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust the values for your environment.
# Never commit the actual .env file — it contains secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# APP_NAME       Display name shown in UI, emails, browser title
# APP_ENV        local | staging | production
# APP_DEBUG      true  → verbose error pages (dev only — เปิดเฉพาะตอน debug บนเครื่องตัวเอง)
#                false → friendly error pages (ค่าเริ่มต้นที่ปลอดภัย / บังคับใช้บน production)
# APP_URL        Full base URL of the app (no trailing slash). Required for
#                emails, QR codes, and absolute links. Examples:
#                  http://localhost/maintenance
#                  https://repair.example.com
# APP_TIMEZONE   PHP timezone identifier (see https://www.php.net/timezones)
# ALLOW_DEMO_DATA  true → อนุญาตให้โหลดข้อมูลตัวอย่าง (Setup + เมนู admin). ตั้ง false บน production
#                  เพื่อกันข้อมูลตัวอย่างปนกับข้อมูลจริง (ค่าเริ่มต้นที่ปลอดภัย)
# -----------------------------------------------------------------------------
APP_NAME="Repair System"
APP_ENV=local
# safe-by-default: ปิด debug ไว้ก่อน — ถ้าจะ dev บนเครื่องตัวเองค่อยตั้ง true ชั่วคราว
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Asia/Bangkok
# safe-by-default: ปิดการโหลดข้อมูลตัวอย่าง — เปิดเป็น true เฉพาะรอบทดลอง/เดโมเท่านั้น
ALLOW_DEMO_DATA=false


# -----------------------------------------------------------------------------
# Database (MySQL / MariaDB)
# -----------------------------------------------------------------------------
# Create the database first, then import: database/schema.sql + database/seed_reference.sql (master data).
# For a demo/eval install also import database/seed_demo.sql — do NOT load it in production.
# Run any database/migrate_*.sql files for optional features.
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=repair_system
DB_CHARSET=utf8mb4
DB_USERNAME=root
DB_PASSWORD=


# -----------------------------------------------------------------------------
# Mail
# -----------------------------------------------------------------------------
# MAIL_DRIVER    log  → writes outgoing mail to storage/mail-logs/ (dev/test)
#                smtp → sends via configured SMTP server (production)
#
# For Gmail:    MAIL_HOST=smtp.gmail.com  MAIL_PORT=587  MAIL_ENCRYPTION=tls
# For Brevo:    MAIL_HOST=smtp-relay.brevo.com  MAIL_PORT=587  MAIL_ENCRYPTION=tls
# For local MailHog: MAIL_HOST=127.0.0.1  MAIL_PORT=1025  (no encryption)
#
# MAIL_QUEUE_BATCH_SIZE         How many mails to send per cron run (default 10)
# MAIL_RETRY_DELAY_SECONDS      Wait before retrying failed delivery (default 300)
# MAIL_PROCESSING_TIMEOUT_SECONDS  Reclaim stuck "processing" jobs (default 900)
# -----------------------------------------------------------------------------
MAIL_DRIVER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=noreply@example.com
# เว้นว่างไว้ = ชื่อผู้ส่งตามชื่อระบบที่ตั้งใน Admin (System Settings) โดยอัตโนมัติ
# ตั้งค่าที่นี่เฉพาะเมื่อต้องการชื่อผู้ส่งคงที่ที่ต่างจากชื่อระบบ (เช่น จัด DMARC/ชื่อฝ่าย)
MAIL_FROM_NAME=
MAIL_REPLY_TO_ADDRESS=
MAIL_REPLY_TO_NAME=
MAIL_QUEUE_BATCH_SIZE=10
MAIL_RETRY_DELAY_SECONDS=300
MAIL_PROCESSING_TIMEOUT_SECONDS=900


# -----------------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------------
# SESSION_NAME                   Cookie name (change if hosting multiple apps
#                                on the same domain to avoid collisions)
# SESSION_SECURE                 true → cookies sent over HTTPS only (ค่าเริ่มต้นที่ปลอดภัย).
#                                ตั้ง false ชั่วคราวเฉพาะ local dev ที่รันบน HTTP เท่านั้น.
# SESSION_IDLE_TIMEOUT_MINUTES   Auto-logout after this many minutes of
#                                inactivity (default 60).
# -----------------------------------------------------------------------------
SESSION_NAME=repair_system_session
# safe-by-default: บังคับ HTTPS-only — ตั้ง false ชั่วคราวเฉพาะ local dev บน HTTP
SESSION_SECURE=true
SESSION_IDLE_TIMEOUT_MINUTES=60


# -----------------------------------------------------------------------------
# Uploads & imports
# -----------------------------------------------------------------------------
# Ticket attachments per submission. _BYTES เป็นไบต์ (5*1024*1024 = 5MB).
# CSV import caps ป้องกัน OOM/timeout — ปรับเพิ่มถ้าองค์กรนำเข้าไฟล์ใหญ่.
# -----------------------------------------------------------------------------
UPLOAD_ATTACHMENT_MAX_FILES=3
UPLOAD_ATTACHMENT_MAX_BYTES=5242880
UPLOAD_IMPORT_ASSET_MAX_BYTES=2097152
UPLOAD_IMPORT_ASSET_MAX_ROWS=500
UPLOAD_IMPORT_USER_MAX_BYTES=1048576
UPLOAD_IMPORT_USER_MAX_ROWS=200


# -----------------------------------------------------------------------------
# Reports
# -----------------------------------------------------------------------------
# REPORT_ASSET_DISPLAY_LIMIT  จำนวนแถวสูงสุดที่ตารางรายงานสุขภาพทรัพย์สินแสดง (เรียงเสี่ยงสุดขึ้นก่อน).
#                             การ์ดสรุปคำนวณจากทรัพย์สินทั้งหมดเสมอ ไม่ติดเพดานนี้ (default 500).
# -----------------------------------------------------------------------------
REPORT_ASSET_DISPLAY_LIMIT=500


# =============================================================================
# Production Checklist
# =============================================================================
# Before going live, make sure to:
#   1. APP_ENV=production · APP_DEBUG=false
#   2. APP_URL set to the real https:// URL
#   3. SESSION_SECURE=true (requires HTTPS)
#   4. MAIL_DRIVER=smtp with valid credentials
#   5. DB_PASSWORD is strong and not the default
#   6. Cron jobs are scheduled (see README.md → Cron section)
#   7. storage/ and public/uploads/ are writable by the web server
#   8. Run /setup wizard once to create the first admin account
# =============================================================================
