APP_NAME="Repair System"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Bangkok

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=repair_system
DB_CHARSET=utf8mb4
DB_USERNAME=root
DB_PASSWORD=

MAIL_DRIVER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="Repair System"
MAIL_REPLY_TO_ADDRESS=
MAIL_REPLY_TO_NAME=
MAIL_QUEUE_BATCH_SIZE=10
MAIL_RETRY_DELAY_SECONDS=300
MAIL_PROCESSING_TIMEOUT_SECONDS=900

SESSION_NAME=repair_system_session
SESSION_SECURE=false
