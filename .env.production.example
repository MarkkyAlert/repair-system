# =============================================================================
# Repair System — PRODUCTION environment
# =============================================================================
# Copy to .env on the PRODUCTION server, then fill in the real values below.
# For the meaning of every setting, see the fully-commented .env.example.
# Differences from .env.example are chosen for a safe live deployment.
# =============================================================================


# ----- Application -----------------------------------------------------------
APP_NAME="Repair System"
APP_ENV=production
APP_DEBUG=false
# The REAL https:// address (no trailing slash). Required for emails, QR codes, links.
APP_URL=https://repair.your-domain.example
APP_TIMEZONE=Asia/Bangkok
# Keep OFF in production so demo data never mixes with real data.
ALLOW_DEMO_DATA=false


# ----- Database --------------------------------------------------------------
# FRESH INSTALL: import database/schema.sql + database/seed_reference.sql via phpMyAdmin.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=repair_system
DB_CHARSET=utf8mb4
DB_USERNAME=repair_system
# MUST be a strong password — never leave this empty in production.
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD


# ----- Mail (send real email in production) ----------------------------------
MAIL_DRIVER=smtp
MAIL_HOST=smtp.your-provider.example
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.example
MAIL_FROM_NAME=
MAIL_REPLY_TO_ADDRESS=
MAIL_REPLY_TO_NAME=
MAIL_QUEUE_BATCH_SIZE=10
MAIL_RETRY_DELAY_SECONDS=300
MAIL_PROCESSING_TIMEOUT_SECONDS=900
MAIL_TIMEOUT=15
MAIL_LOG_PATH=storage/mail-logs


# ----- Session (HTTPS-only in production) ------------------------------------
SESSION_NAME=repair_system_session
SESSION_SECURE=true
SESSION_IDLE_TIMEOUT_MINUTES=60


# ----- Uploads & imports -----------------------------------------------------
UPLOAD_ATTACHMENT_MAX_FILES=3
UPLOAD_ATTACHMENT_MAX_BYTES=5242880
UPLOAD_IMPORT_ASSET_MAX_BYTES=2097152
UPLOAD_IMPORT_ASSET_MAX_ROWS=500
UPLOAD_IMPORT_USER_MAX_BYTES=1048576
UPLOAD_IMPORT_USER_MAX_ROWS=50


# ----- Reports ---------------------------------------------------------------
REPORT_ASSET_DISPLAY_LIMIT=500


# ----- Storage, backups & security -------------------------------------------
BRANDING_UPLOAD_DIR=storage/uploads/branding
MYSQLDUMP_BIN=mysqldump
BACKUP_TIMEOUT_SECONDS=900
# Keep CSP enforced (not report-only) in production.
CSP_REPORT_ONLY=false


# =============================================================================
# Before going live: run /check-requirements.php, set a strong DB_PASSWORD,
# confirm HTTPS + SESSION_SECURE=true, schedule the cron jobs (see the setup
# guide), and run /setup once to create the first admin.
# =============================================================================
