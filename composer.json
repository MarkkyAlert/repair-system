{
  "name": "your-org/repair-system",
  "description": "Repair & maintenance request management system — deployable template",
  "type": "project",
  "require": {
    "php": "^8.1",
    "phpmailer/phpmailer": "^6.10",
    "phpoffice/phpspreadsheet": "^2.1",
    "dompdf/dompdf": "^3.0",
    "endroid/qr-code": "^5.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "files": [
      "app/Helpers/helpers.php"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "test": "php tests/run.php"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.2",
    "smalot/pdfparser": "^2.12"
  }
}
